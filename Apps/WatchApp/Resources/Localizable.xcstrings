    "Start a Freedive": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar una apnea"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Démarrer une apnée"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inizia un’apnea"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フリーダイビングを開始"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Почати фрідайв"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Freitauchen starten"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar apneia"
          }
        }
      }
    },
    "Started a session by mistake? On the summary after it ends, tap Discard (and confirm) to throw it away — it's removed from the watch and won't appear on your iPhone.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Iniciaste una sesión por error? En el resumen tras terminarla, toca Descartar (y confirma) para tirarla: se elimina del reloj y no aparecerá en tu iPhone."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez démarré une session par erreur ? Sur le récapitulatif après sa fin, touchez Abandonner (et confirmez) pour la jeter — elle est supprimée de la montre et n’apparaîtra pas sur votre iPhone."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai avviato una sessione per sbaglio? Nel riepilogo dopo la fine, tocca Scarta (e conferma) per eliminarla: viene rimossa dall’orologio e non apparirà sull’iPhone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "誤ってセッションを開始しましたか？終了後のサマリーで「破棄」をタップして確定すると破棄できます——時計から削除され、iPhoneにも表示されません。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Почали сесію помилково? У підсумку після її завершення торкніться Відкинути (і підтвердьте), щоб позбутися її — вона видаляється з годинника й не з’явиться на вашому iPhone."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aus Versehen eine Session gestartet? Tippe in der Zusammenfassung nach dem Ende auf „Verwerfen“ (und bestätige), um sie wegzuwerfen — sie wird von der Uhr entfernt und erscheint nicht auf deinem iPhone."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciou uma sessão por engano? No resumo após o término, toque em Descartar (e confirme) para jogá-la fora — ela é removida do relógio e não aparece no seu iPhone."
          }
        }
      }
    },
