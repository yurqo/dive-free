    "Scroll the Crown to End and press the Action button. In the confirm dialog, Action + side ends and the Action button cancels.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gira la corona hasta Terminar y pulsa el botón Acción. En el diálogo de confirmación, Acción + lateral termina y el botón Acción cancela."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tournez la couronne jusqu’à Terminer et appuyez sur le bouton Action. Dans la boîte de dialogue de confirmation, Action + latéral termine et le bouton Action annule."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ruota la corona su Termina e premi il tasto Azione. Nella finestra di conferma, Azione + laterale termina e il tasto Azione annulla."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クラウンを回して終了に合わせ、アクションボタンを押します。確認ダイアログでは、アクション+サイドで終了、アクションボタンでキャンセルします。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Прокрутіть головку Digital Crown до Завершити й натисніть кнопку Дії. У діалозі підтвердження Дія + бічна завершує, а кнопка Дії скасовує."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Scroll mit der Crown zu „Beenden“ und drück den Action Button. Im Bestätigungsdialog beendet Action + Seite, und der Action Button bricht ab."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Gire a Crown até Encerrar e pressione o botão de Ação. Na caixa de confirmação, Ação + lateral encerra e o botão de Ação cancela."
          }
        }
      }
    },
