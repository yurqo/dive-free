          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クラウンを回して試す"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Покрутіть головку Digital Crown, щоб спробувати"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreh die Crown, um es auszuprobieren"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Gire a Crown para experimentar"
          }
        }
      }
    },
    "Turn the Crown to unlock, then tap to end.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gira la corona para desbloquear y luego toca para terminar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tournez la couronne pour déverrouiller, puis touchez pour terminer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ruota la corona per sbloccare, poi tocca per terminare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クラウンを回してロックを解除し、タップして終了します。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Покрутіть головку Digital Crown, щоб розблокувати, потім торкніться, щоб завершити."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreh die Crown zum Entsperren, dann tippe zum Beenden."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Gire a Crown para desbloquear, depois toque para encerrar."
          }
        }
      }
    },
