    "Action + side to end · Action button to cancel.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acción + lateral para terminar · botón Acción para cancelar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Action + latéral pour terminer · bouton Action pour annuler."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Azione + laterale per terminare · tasto Azione per annullare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクション+サイドで終了・アクションボタンでキャンセル"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Дія + бічна, щоб завершити · кнопка Дії, щоб скасувати."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Action + Seite zum Beenden · Action Button zum Abbrechen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ação + lateral para encerrar · botão de Ação para cancelar."
          }
        }
      }
    },
