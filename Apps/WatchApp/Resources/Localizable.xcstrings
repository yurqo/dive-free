    "Set on iPhone. Applies to your next session.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se ajusta en el iPhone. Se aplica a tu próxima sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Se règle sur l’iPhone. S’applique à votre prochaine session."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Si imposta sull’iPhone. Vale per la prossima sessione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhoneで設定します。次のセッションから適用されます。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Налаштовується на iPhone. Застосовується до наступної сесії."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Am iPhone eingestellt. Gilt ab deiner nächsten Session."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Definido no iPhone. Vale para a sua próxima sessão."
          }
        }
      }
    },
    "Set your most-used marker as the default in Settings — it's pre-selected and what the Action button drops underwater.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Configura tu marcador más usado como predeterminado en Ajustes: queda preseleccionado y es lo que suelta el botón Acción bajo el agua."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Définissez votre repère le plus utilisé comme repère par défaut dans Réglages — il est présélectionné et c’est ce que pose le bouton Action sous l’eau."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Imposta il marcatore che usi di più come predefinito in Impostazioni: è preselezionato ed è ciò che il tasto Azione rilascia sott’acqua."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "よく使うマーカーを設定でデフォルトに設定しましょう——あらかじめ選択され、水中でアクションボタンが記録するのがこれです。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Зробіть найуживанішу позначку типовою в Налаштуваннях — вона обрана заздалегідь, і саме її ставить кнопка Дії під водою."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lege deine meistgenutzte Markierung als Standard in den Einstellungen fest — sie ist vorausgewählt und wird vom Action Button unter Wasser gesetzt."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Defina o marcador que mais usa como padrão nos Ajustes — ele fica pré-selecionado e é o que o botão de Ação solta debaixo d'água."
          }
        }
      }
    },
