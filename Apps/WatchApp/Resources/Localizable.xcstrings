            "value": "Sur la montre"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sull’orologio"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "時計に保存"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "На годиннику"
          }
        },
