    "Turn the Crown to feel each speed before you pick. Slower is easier underwater.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gira la corona para sentir cada velocidad antes de elegir. Más lento es más fácil bajo el agua."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tournez la couronne pour sentir chaque vitesse avant de choisir. Plus lent, c’est plus facile sous l’eau."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ruota la corona per provare ogni velocità prima di scegliere. Più lento è più facile sott’acqua."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選ぶ前にクラウンを回して、それぞれの速度を試しましょう。水中では遅いほうが扱いやすいです。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Покрутіть головку Digital Crown, щоб відчути кожну швидкість перед вибором. Повільніше — легше під водою."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dreh die Crown, um jedes Tempo vor der Wahl zu erfühlen. Langsamer ist unter Wasser einfacher."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Gire a Crown para sentir cada velocidade antes de escolher. Mais devagar é mais fácil debaixo d'água."
          }
        }
      }
    },
    "Turn the Crown to try it": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gira la corona para probarlo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tournez la couronne pour l’essayer"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
