    "Drops the selected marker while underwater, or confirms the selected menu item on the surface.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Suelta el marcador seleccionado bajo el agua, o confirma el elemento de menú seleccionado en la superficie."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pose le repère sélectionné sous l’eau, ou confirme l’élément de menu sélectionné en surface."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rilascia il marcatore selezionato sott’acqua, o conferma la voce di menu selezionata in superficie."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "水中では選択中のマーカーを記録し、水面では選択中のメニュー項目を確定します。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ставить вибрану позначку під водою або підтверджує вибраний пункт меню на поверхні."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Setzt unter Wasser die ausgewählte Markierung oder bestätigt an der Oberfläche den ausgewählten Menüpunkt."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Solta o marcador selecionado debaixo d'água, ou confirma o item de menu selecionado na superfície."
          }
        }
      }
    },
