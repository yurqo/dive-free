    "Fake device capabilities to preview the non-Ultra flows. Restart the app after changing. Simulator only.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Simula las capacidades del dispositivo para previsualizar los flujos sin Ultra. Reinicia la app tras cambiarlo. Solo en el simulador."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Simule les capacités de l’appareil pour prévisualiser les parcours hors Ultra. Redémarrez l’app après modification. Simulateur uniquement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Simula le capacità del dispositivo per visualizzare in anteprima i flussi non Ultra. Riavvia l’app dopo la modifica. Solo simulatore."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイスの機能を疑似的に切り替えて、Ultra以外のフローをプレビューします。変更後はアプリを再起動してください。シミュレータ専用です。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Імітує можливості пристрою для попереднього перегляду сценаріїв без Ultra. Після зміни перезапустіть застосунок. Лише для симулятора."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerätefähigkeiten simulieren, um die Nicht-Ultra-Abläufe vorzuschauen. Nach der Änderung App neu starten. Nur Simulator."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Simular recursos do dispositivo para pré-visualizar os fluxos sem Ultra. Reinicie o app após alterar. Apenas no simulador."
          }
        }
      }
    },
