            "value": "Температура"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Temperatur"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Temperatura"
          }
        }
      }
    },
    "The arrow top-left shows GPS: a spinner while acquiring, then accuracy. Let it fix before you dive to tag your spot — GPS can't track underwater.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La flecha arriba a la izquierda muestra el GPS: un indicador giratorio mientras adquiere y luego la precisión. Deja que fije la posición antes de sumergirte para etiquetar tu punto: el GPS no puede rastrear bajo el agua."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La flèche en haut à gauche indique le GPS : un indicateur d’activité pendant l’acquisition, puis la précision. Laissez-le se caler avant de plonger pour marquer votre spot — le GPS ne fonctionne pas sous l’eau."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La freccia in alto a sinistra mostra il GPS: un indicatore rotante durante l’acquisizione, poi la precisione. Lascia che agganci la posizione prima di immergerti per segnare il tuo spot — il GPS non funziona sott’acqua."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "左上の矢印はGPSを示します。取得中はスピナー、その後は精度が表示されます。スポットを記録するため、潜る前に位置を確定させましょう——GPSは水中では追跡できません。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Стрілка вгорі ліворуч показує GPS: спінер під час визначення, потім точність. Дайте йому визначити позицію перед зануренням, щоб позначити місце — під водою GPS не працює."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Pfeil oben links zeigt GPS: ein Rädchen beim Suchen, dann die Genauigkeit. Lass es fixieren, bevor du tauchst, um deinen Spot zu markieren — unter Wasser kann GPS nicht orten."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A seta no canto superior esquerdo mostra o GPS: um indicador girando enquanto busca, depois a precisão. Deixe-o fixar antes de mergulhar para marcar seu local — o GPS não rastreia debaixo d'água."
          }
        }
      }
    },
    "The screen locks underwater. Turn the Digital Crown to pick a marker, then press the Action button to drop it.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La pantalla se bloquea bajo el agua. Gira la Corona Digital para elegir un marcador y luego pulsa el botón Acción para soltarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’écran se verrouille sous l’eau. Tournez la Digital Crown pour choisir un repère, puis appuyez sur le bouton Action pour le poser."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo schermo si blocca sott’acqua. Ruota la Digital Crown per scegliere un marcatore, poi premi il tasto Azione per rilasciarlo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画面は水中でロックされます。Digital Crownを回してマーカーを選び、アクションボタンを押して記録します。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Екран блокується під водою. Покрутіть Digital Crown, щоб вибрати позначку, потім натисніть кнопку Дії, щоб поставити її."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Bildschirm sperrt unter Wasser. Dreh die Digital Crown, um eine Markierung zu wählen, und drück dann den Action Button, um sie zu setzen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A tela bloqueia debaixo d'água. Gire a Digital Crown para escolher um marcador e pressione o botão de Ação para soltá-lo."
          }
        }
      }
    },
    "This removes the session from your watch and iPhone.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina la sesión de tu reloj y de tu iPhone."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprime la session de votre montre et de votre iPhone."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo rimuove la sessione dall’orologio e dall’iPhone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッションが時計とiPhoneから削除されます。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це видалить сесію з годинника та iPhone."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das entfernt die Session von deiner Uhr und deinem iPhone."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso remove a sessão do seu relógio e do seu iPhone."
          }
        }
      }
    },
    "This throws away the session — it won't be kept on your watch or appear on your iPhone.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto descarta la sesión: no se guardará en el reloj ni aparecerá en el iPhone."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela abandonne la session — elle ne sera pas conservée sur la montre ni affichée sur l’iPhone."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo scarta la sessione: non verrà conservata sull’orologio né apparirà sull’iPhone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッションを破棄します。時計に保存されず、iPhoneにも表示されません。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це відкине сесію — вона не збережеться на годиннику й не з’явиться на iPhone."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das wirft die Session weg — sie wird nicht auf deiner Uhr behalten und erscheint nicht auf deinem iPhone."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso descarta a sessão — ela não será mantida no seu relógio nem aparecerá no seu iPhone."
          }
        }
      }
    },
