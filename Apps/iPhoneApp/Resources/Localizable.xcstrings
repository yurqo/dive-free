          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vos repères"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I tuoi marcatori"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "マイマーカー"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seus marcadores"
          }
        },
        "uk" : {
