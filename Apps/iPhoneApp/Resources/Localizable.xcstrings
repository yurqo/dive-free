          "stringUnit" : {
            "state" : "translated",
            "value" : "Überschreibt den automatischen Ortsnamen. Einmal bearbeitet, wird er nicht mehr automatisch ersetzt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anula el nombre de ubicación automático. Una vez editado, no se reemplazará automáticamente."
