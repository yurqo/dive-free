    "Monthly snack" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Monatlicher Snack"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aperitivo mensual"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En-cas mensuel"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spuntino mensile"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "毎月のおやつ"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lanche mensal"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Щомісячний перекус"
          }
        }
      }
    },
    "Monthly snack is an auto-renewing subscription. It renews each month at the price shown until you cancel. Payment is charged to your Apple Account at confirmation, and again each period unless you cancel at least 24 hours before it ends. Manage or cancel anytime in Settings." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der monatliche Snack ist ein automatisch verlängertes Abo. Es verlängert sich jeden Monat zum angezeigten Preis, bis du kündigst. Die Zahlung wird bei Bestätigung deinem Apple-Account belastet und dann jede Periode erneut, sofern du nicht mindestens 24 Stunden vor Ende kündigst. Jederzeit in den Einstellungen verwalten oder kündigen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El aperitivo mensual es una suscripción de renovación automática. Se renueva cada mes al precio mostrado hasta que la canceles. El pago se carga a tu cuenta de Apple al confirmar, y de nuevo cada periodo salvo que canceles al menos 24 horas antes de que termine. Gestiónala o cancélala cuando quieras en Ajustes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L’en-cas mensuel est un abonnement à renouvellement automatique. Il se renouvelle chaque mois au prix indiqué jusqu’à annulation. Le paiement est prélevé sur votre compte Apple à la confirmation, puis à chaque période, sauf annulation au moins 24 heures avant la fin. Gérez-le ou annulez-le à tout moment dans Réglages."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lo spuntino mensile è un abbonamento a rinnovo automatico. Si rinnova ogni mese al prezzo indicato finché non lo annulli. Il pagamento viene addebitato sul tuo Apple Account alla conferma e a ogni periodo, salvo annullamento almeno 24 ore prima della fine. Gestiscilo o annullalo quando vuoi in Impostazioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "毎月のおやつは自動更新のサブスクリプションです。キャンセルするまで、表示された価格で毎月更新されます。料金は確定時にApple Accountへ請求され、終了の24時間以上前にキャンセルしない限り毎期請求されます。管理や解約は設定でいつでも行えます。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O lanche mensal é uma assinatura com renovação automática. Ela se renova a cada mês pelo preço exibido até você cancelar. A cobrança é feita na sua Conta Apple na confirmação e novamente a cada período, a menos que você cancele pelo menos 24 horas antes do fim. Gerencie ou cancele a qualquer momento nos Ajustes."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Щомісячний перекус — це підписка з автоматичним поновленням. Вона поновлюється щомісяця за показаною ціною, доки ви її не скасуєте. Оплата стягується з вашого облікового запису Apple під час підтвердження і потім щоперіоду, якщо ви не скасуєте принаймні за 24 години до завершення. Керуйте нею або скасуйте будь-коли в Налаштуваннях."
          }
        }
      }
    },
    "More accurate dive-spot location and surface track. Drains the battery faster. Applies to your next session." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Genauere Tauchplatz-Position und Oberflächenroute. Verbraucht den Akku schneller. Gilt ab deiner nächsten Session."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ubicación del punto de buceo y recorrido en superficie más precisos. Consume la batería más rápido. Se aplica a tu próxima sesión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Localisation du spot et tracé en surface plus précis. Décharge la batterie plus vite. S’applique à votre prochaine session."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Posizione dello spot e traccia in superficie più precise. Consuma la batteria più in fretta. Vale per la prossima sessione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ダイブスポットの位置と水面トラックがより正確になります。バッテリーの消費が速くなります。次のセッションから適用されます。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Localização do ponto de mergulho e trajeto de superfície mais precisos. Consome a bateria mais rápido. Vale para a sua próxima sessão."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Точніше визначення місця занурення та поверхневого треку. Швидше розряджає акумулятор. Застосовується до наступної сесії."
          }
        }
      }
    },
