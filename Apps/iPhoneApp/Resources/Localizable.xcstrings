          "stringUnit" : {
            "state" : "translated",
            "value" : "Plongez toujours dans les limites de votre formation et de votre certification."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Immergiti sempre nei limiti della tua formazione e certificazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "常に自分の訓練と資格の範囲内で潜ってください。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mergulhe sempre dentro do seu treinamento e da sua certificação."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Завжди занурюйтеся в межах своєї підготовки та сертифікації."
          }
        }
      }
    },
