    "New to the watch controls? There's a short guide on the watch itself, on its Start screen." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neu bei der Bedienung der Uhr? Auf der Uhr selbst gibt es eine kurze Anleitung, auf ihrem Startbildschirm."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Nuevo con los controles del reloj? Hay una breve guía en el propio reloj, en su pantalla de inicio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nouveau avec les commandes de la montre ? Un petit guide est disponible sur la montre elle-même, sur son écran de démarrage."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuovo ai comandi dell’orologio? C’è una breve guida sull’orologio stesso, nella schermata iniziale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "時計の操作は初めてですか？時計本体のスタート画面に、短いガイドがあります。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Novo nos controles do relógio? Há um guia rápido no próprio relógio, na tela inicial."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
