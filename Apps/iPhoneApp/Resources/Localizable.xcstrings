          }
        }
      }
    },
    "Back at the surface, end the session on the watch. It saves itself and appears on your iPhone and iPad, where you can relive it with depth charts, maps, and photos." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zurück an der Oberfläche beendest du die Session auf der Uhr. Sie speichert sich selbst und erscheint auf iPhone und iPad, wo du sie mit Tiefendiagrammen, Karten und Fotos noch einmal erleben kannst."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De vuelta en la superficie, termina la sesión en el reloj. Se guarda sola y aparece en tu iPhone y iPad, donde puedes revivirla con gráficas de profundidad, mapas y fotos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De retour en surface, terminez la session sur la montre. Elle s’enregistre d’elle-même et apparaît sur votre iPhone et votre iPad, où vous pouvez la revivre avec les profils de profondeur, les cartes et les photos."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tornato in superficie, termina la sessione sull’orologio. Si salva da sola e compare su iPhone e iPad, dove puoi riviverla con grafici di profondità, mappe e foto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "水面に戻ったら、時計でセッションを終了します。自動的に保存され、iPhoneとiPadに表示されて、水深グラフやマップ、写真で振り返れます。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De volta à superfície, encerre a sessão no relógio. Ela se salva sozinha e aparece no seu iPhone e iPad, onde você pode revivê-la com gráficos de profundidade, mapas e fotos."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Повернувшись на поверхню, завершіть сесію на годиннику. Вона збережеться сама й з’явиться на вашому iPhone та iPad, де ви зможете пережити її знову з графіками глибини, мапами й фото."
          }
        }
      }
    },
