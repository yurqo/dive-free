          }
        }
      }
    },
    "Your photos stay in your own photo library and iCloud — Dive Free simply points to them. They're never uploaded to us, and they aren't sent to Strava." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Fotos bleiben in deiner eigenen Fotomediathek und iCloud — Dive Free verweist nur darauf. Sie werden nie zu uns hochgeladen und nicht an Strava gesendet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus fotos permanecen en tu propia fototeca y en iCloud; Dive Free simplemente apunta a ellas. Nunca se suben a nosotros ni se envían a Strava."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vos photos restent dans votre propre photothèque et dans iCloud — Dive Free y fait simplement référence. Elles ne nous sont jamais envoyées, ni transmises à Strava."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le tue foto restano nella tua libreria e su iCloud — Dive Free si limita a puntarvi. Non vengono mai caricate da noi e non vengono inviate a Strava."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "写真はあなた自身の写真ライブラリとiCloudに残り、Dive Freeはそれを参照するだけです。私たちにアップロードされることも、Stravaに送られることもありません。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suas fotos permanecem na sua própria biblioteca de fotos e no iCloud — o Dive Free apenas aponta para elas. Elas nunca são enviadas para nós, nem para o Strava."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваші фото залишаються у вашій медіатеці та в iCloud — Dive Free лише посилається на них. Вони ніколи не завантажуються до нас і не надсилаються в Strava."
          }
        }
      }
    },
    "Your saved dives, spots, and photos sync across iPhone and iPad through your own iCloud, so your log looks the same everywhere." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine gespeicherten Tauchgänge, Spots und Fotos synchronisieren über deine eigene iCloud zwischen iPhone und iPad, sodass dein Logbuch überall gleich aussieht."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus inmersiones, puntos y fotos guardados se sincronizan entre el iPhone y el iPad mediante tu propia iCloud, para que tu registro se vea igual en todas partes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vos plongées, spots et photos enregistrés se synchronisent entre l’iPhone et l’iPad via votre propre iCloud, pour que votre carnet soit identique partout."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le immersioni, gli spot e le foto salvati si sincronizzano tra iPhone e iPad tramite il tuo iCloud, così il tuo diario è identico ovunque."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保存したダイブ、スポット、写真は、あなた自身のiCloudを通じてiPhoneとiPadの間で同期されるので、ログはどこでも同じように表示されます。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seus mergulhos, locais e fotos salvos sincronizam entre iPhone e iPad pela sua própria conta do iCloud, para que seu registro fique igual em todo lugar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
