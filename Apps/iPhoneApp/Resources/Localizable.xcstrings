          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Marcatori"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "マーカー"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
