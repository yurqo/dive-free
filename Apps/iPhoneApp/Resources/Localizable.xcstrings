    "Photos can't be added to a Strava activity through Strava's public tools, so add those on Strava yourself if you'd like." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fotos lassen sich über Stravas öffentliche Werkzeuge nicht zu einer Strava-Aktivität hinzufügen, also füge sie bei Bedarf selbst auf Strava hinzu."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pueden añadir fotos a una actividad de Strava mediante las herramientas públicas de Strava, así que añádelas tú mismo en Strava si quieres."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les photos ne peuvent pas être ajoutées à une activité Strava via les outils publics de Strava ; ajoutez-les vous-même sur Strava si vous le souhaitez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le foto non possono essere aggiunte a un’attività Strava tramite gli strumenti pubblici di Strava, quindi aggiungile tu stesso su Strava se vuoi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stravaの公開ツールではアクティビティに写真を追加できないため、必要な場合はStrava上でご自身で追加してください。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fotos não podem ser adicionadas a uma atividade do Strava pelas ferramentas públicas do Strava, então adicione-as você mesmo no Strava, se quiser."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фото не можна додати до активності Strava через публічні інструменти Strava, тож за бажання додайте їх у Strava самостійно."
          }
        }
      }
    },
    "Photos from This Dive" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fotos aus diesem Tauchgang"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fotos de esta inmersión"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Photos de cette plongée"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foto di questa immersione"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このダイブの写真"
          }
        },
        "pt" : {
