    "Custom lets you mix units per measurement — e.g. meters for depth with Fahrenheit water temperature." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mit „Eigen“ kannst du Einheiten je Messung mischen — z. B. Meter für die Tiefe und Fahrenheit für die Wassertemperatur."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Personalizado te permite mezclar unidades por medida, por ejemplo metros para la profundidad con temperatura del agua en Fahrenheit."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Personnalisé vous permet de mélanger les unités par mesure — par exemple des mètres pour la profondeur et des Fahrenheit pour la température de l’eau."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Personalizzato ti permette di mescolare le unità per ogni misura — ad esempio metri per la profondità e Fahrenheit per la temperatura dell’acqua."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カスタムでは、測定項目ごとに単位を組み合わせられます。たとえば水深はメートル、水温は華氏、というように。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Personalizado permite misturar unidades por medida — por ex. metros para a profundidade com Fahrenheit para a temperatura da água."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Власний дозволяє змішувати одиниці для кожного виміру — наприклад, метри для глибини та Фаренгейти для температури води."
          }
        }
      }
    },
