    "Start a session on your Apple Watch to see it here." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Starte eine Session auf deiner Apple Watch, um sie hier zu sehen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inicia una sesión en tu Apple Watch para verla aquí."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Démarrez une session sur votre Apple Watch pour la voir ici."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avvia una sessione sull’Apple Watch per vederla qui."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Watchでセッションを開始すると、ここに表示されます。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inicie uma sessão no seu Apple Watch para vê-la aqui."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Почніть сесію на Apple Watch, щоб побачити її тут."
          }
        }
      }
    },
    "Start Session" : {
      "extractionState" : "stale",
