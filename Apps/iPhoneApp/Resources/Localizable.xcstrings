    "Auto-clean synced" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Synchronisierte autom. löschen"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Limpieza automática de lo sincronizado"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nettoyage auto des synchronisés"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pulizia automatica dei sincronizzati"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "同期済みを自動削除"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Limpar sincronizados"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Автоочищення синхронізованих"
          }
        }
      }
    },
    "Automatically remove older sessions from this watch once they're safely on your iPhone. Your dives stay on iPhone and iCloud — this only frees watch space." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entfernt ältere Sessions automatisch von dieser Uhr, sobald sie sicher auf deinem iPhone sind. Deine Tauchgänge bleiben auf iPhone und iCloud — das gibt nur Speicher auf der Uhr frei."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elimina automáticamente las sesiones más antiguas de este reloj una vez que estén a salvo en tu iPhone. Tus inmersiones permanecen en el iPhone y en iCloud; esto solo libera espacio en el reloj."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supprime automatiquement les sessions les plus anciennes de cette montre une fois qu’elles sont bien sur votre iPhone. Vos plongées restent sur l’iPhone et dans iCloud — cela ne libère que l’espace de la montre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rimuove automaticamente le sessioni più vecchie da questo orologio una volta che sono al sicuro sull’iPhone. Le tue immersioni restano sull’iPhone e su iCloud: questo libera solo spazio sull’orologio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iPhoneに安全に保存された後、古いセッションをこの時計から自動的に削除します。ダイブはiPhoneとiCloudに残るので、これは時計の空き容量を増やすだけです。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remove automaticamente sessões antigas deste relógio assim que estiverem seguras no seu iPhone. Seus mergulhos permanecem no iPhone e no iCloud — isso só libera espaço no relógio."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Автоматично видаляє старіші сесії з цього годинника, щойно вони безпечно опиняться на iPhone. Ваші занурення залишаються на iPhone та в iCloud — це лише звільняє місце на годиннику."
          }
        }
      }
    },
    "Avg surface" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ø Oberfläche"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Superficie media"
          }
        },
        "fr" : {
