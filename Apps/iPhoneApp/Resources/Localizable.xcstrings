    "Re-send every session on this watch to your iPhone — use it if some dives didn't show up there." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sendet jede Session dieser Uhr erneut an dein iPhone — nutze es, falls dort manche Tauchgänge nicht auftauchten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reenvía al iPhone todas las sesiones de este reloj: úsalo si alguna inmersión no apareció allí."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Renvoyez vers l’iPhone toutes les sessions de cette montre — utile si certaines plongées n’y sont pas apparues."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reinvia all’iPhone tutte le sessioni di questo orologio: usalo se qualche immersione non è comparsa lì."
