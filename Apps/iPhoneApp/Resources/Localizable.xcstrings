          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gira la corona hasta Terminar y pulsa el botón Acción. En el diálogo de confirmación, Acción + lateral termina y el botón Acción cancela."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tournez la couronne jusqu’à Terminer et appuyez sur le bouton Action. Dans la boîte de dialogue de confirmation, Action + latéral termine et le bouton Action annule."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ruota la corona su Termina e premi il tasto Azione. Nella finestra di conferma, Azione + laterale termina e il tasto Azione annulla."
          }
        },
        "ja" : {
          "stringUnit" : {
