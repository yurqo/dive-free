    "Relive a dive with the photos and videos you took that day — including shots from an underwater camera you've imported to your phone." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erlebe einen Tauchgang mit den Fotos und Videos noch einmal, die du an dem Tag aufgenommen hast — auch Aufnahmen einer Unterwasserkamera, die du auf dein iPhone importiert hast."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Revive una inmersión con las fotos y vídeos que tomaste ese día, incluidas las tomas de una cámara subacuática que hayas importado a tu teléfono."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Revivez une plongée avec les photos et vidéos prises ce jour-là — y compris les prises d’une caméra sous-marine importées sur votre téléphone."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rivivi un’immersione con le foto e i video scattati quel giorno — inclusi gli scatti di una fotocamera subacquea che hai importato sul telefono."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "その日に撮った写真やビデオでダイブを振り返れます——iPhoneに読み込んだ水中カメラの写真も含めて。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reviva um mergulho com as fotos e os vídeos que você fez naquele dia — incluindo imagens de uma câmera subaquática que você importou para o telefone."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Переживіть занурення знову з фото та відео, які ви зняли того дня — зокрема кадрами з підводної камери, які ви імпортували на телефон."
          }
        }
      }
    },
